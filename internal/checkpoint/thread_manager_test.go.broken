package checkpoint

import (
	"context"
	"testing"

	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
	"github.com/zero-day-ai/gibson/internal/types"
)

// mockThreadStore is a simple in-memory mock for testing
type mockThreadStore struct {
	threads map[string]*Thread
}

func newMockThreadStore() *mockThreadStore {
	return &mockThreadStore{
		threads: make(map[string]*Thread),
	}
}

func (m *mockThreadStore) SaveThread(ctx context.Context, thread *Thread) error {
	m.threads[thread.ID] = thread
	return nil
}

func (m *mockThreadStore) GetThread(ctx context.Context, threadID string) (*Thread, error) {
	thread, ok := m.threads[threadID]
	if !ok {
		return nil, ErrThreadNotFound
	}
	return thread, nil
}

func (m *mockThreadStore) ListThreads(ctx context.Context, missionID types.ID) ([]*Thread, error) {
	var threads []*Thread
	for _, t := range m.threads {
		if t.MissionID == missionID {
			threads = append(threads, t)
		}
	}
	return threads, nil
}

func (m *mockThreadStore) UpdateThread(ctx context.Context, thread *Thread) error {
	m.threads[thread.ID] = thread
	return nil
}

func (m *mockThreadStore) DeleteThread(ctx context.Context, threadID string) error {
	delete(m.threads, threadID)
	return nil
}

// mockCheckpointStore is a simple in-memory mock for testing
type mockCheckpointStore struct {
	checkpoints map[string]*Checkpoint
}

func newMockCheckpointStore() *mockCheckpointStore {
	return &mockCheckpointStore{
		checkpoints: make(map[string]*Checkpoint),
	}
}

func (m *mockCheckpointStore) SaveCheckpoint(ctx context.Context, checkpoint *Checkpoint) error {
	m.checkpoints[checkpoint.ID] = checkpoint
	return nil
}

func (m *mockCheckpointStore) GetCheckpoint(ctx context.Context, checkpointID string) (*Checkpoint, error) {
	checkpoint, ok := m.checkpoints[checkpointID]
	if !ok {
		return nil, ErrCheckpointNotFound
	}
	return checkpoint, nil
}

func (m *mockCheckpointStore) ListCheckpoints(ctx context.Context, threadID string, opts HistoryOptions) ([]*Checkpoint, error) {
	var checkpoints []*Checkpoint
	for _, c := range m.checkpoints {
		if c.ThreadID == threadID {
			checkpoints = append(checkpoints, c)
		}
	}
	return checkpoints, nil
}

func (m *mockCheckpointStore) GetLatestCheckpoint(ctx context.Context, threadID string) (*Checkpoint, error) {
	var latest *Checkpoint
	for _, c := range m.checkpoints {
		if c.ThreadID == threadID {
			if latest == nil || c.CreatedAt.After(latest.CreatedAt) {
				latest = c
			}
		}
	}
	if latest == nil {
		return nil, ErrCheckpointNotFound
	}
	return latest, nil
}

func (m *mockCheckpointStore) DeleteCheckpoint(ctx context.Context, checkpointID string) error {
	delete(m.checkpoints, checkpointID)
	return nil
}

func (m *mockCheckpointStore) DeleteThreadCheckpoints(ctx context.Context, threadID string) error {
	for id, c := range m.checkpoints {
		if c.ThreadID == threadID {
			delete(m.checkpoints, id)
		}
	}
	return nil
}

func TestThreadManager_CreateThread(t *testing.T) {
	ctx := context.Background()
	threadStore := newMockThreadStore()
	checkpointStore := newMockCheckpointStore()
	tm := NewThreadManager(threadStore, checkpointStore)

	missionID := types.NewID()

	// Test basic thread creation
	thread, err := tm.CreateThread(ctx, missionID)
	require.NoError(t, err)
	assert.NotEmpty(t, thread.ID)
	assert.Equal(t, missionID, thread.MissionID)
	assert.Equal(t, ThreadStatusActive, thread.Status)

	// Test thread creation with options
	thread2, err := tm.CreateThread(ctx, missionID,
		WithThreadID("test-thread-id"),
		WithLabel("test-label"),
		WithStrategy("aggressive"),
		WithPriority(10),
		WithMetadata(map[string]string{"key": "value"}),
	)
	require.NoError(t, err)
	assert.Equal(t, "test-thread-id", thread2.ID)
	assert.Equal(t, "test-label", thread2.Label)
	assert.Equal(t, "aggressive", thread2.Strategy)
	assert.Equal(t, 10, thread2.Priority)
	assert.Equal(t, "value", thread2.Metadata["key"])

	// Test invalid mission ID
	_, err = tm.CreateThread(ctx, types.ID(""))
	assert.ErrorIs(t, err, ErrInvalidMissionID)
}

func TestThreadManager_CreateBranchThread(t *testing.T) {
	ctx := context.Background()
	threadStore := newMockThreadStore()
	checkpointStore := newMockCheckpointStore()
	tm := NewThreadManager(threadStore, checkpointStore)

	missionID := types.NewID()

	// Create parent thread
	parentThread, err := tm.CreateThread(ctx, missionID, WithThreadID("parent"))
	require.NoError(t, err)

	// Create checkpoint for parent thread
	checkpoint := NewCheckpoint(missionID, parentThread.ID)
	checkpoint.ID = "checkpoint-1"
	err = checkpointStore.SaveCheckpoint(ctx, checkpoint)
	require.NoError(t, err)

	// Create branch thread
	branchThread, err := tm.CreateBranchThread(ctx, parentThread.ID, checkpoint.ID,
		WithThreadID("branch"),
		WithLabel("branch-label"),
	)
	require.NoError(t, err)
	assert.Equal(t, "branch", branchThread.ID)
	assert.Equal(t, "branch-label", branchThread.Label)
	assert.Equal(t, parentThread.ID, branchThread.ParentThread)
	assert.Equal(t, checkpoint.ID, branchThread.BranchCheckpointID)

	// Test invalid parent thread
	_, err = tm.CreateBranchThread(ctx, "", checkpoint.ID)
	assert.ErrorIs(t, err, ErrInvalidThreadID)

	// Test invalid checkpoint
	_, err = tm.CreateBranchThread(ctx, parentThread.ID, "")
	assert.ErrorIs(t, err, ErrInvalidCheckpointID)

	// Test non-existent parent thread
	_, err = tm.CreateBranchThread(ctx, "nonexistent", checkpoint.ID)
	assert.Error(t, err)

	// Test checkpoint doesn't belong to parent
	otherThread, err := tm.CreateThread(ctx, missionID, WithThreadID("other"))
	require.NoError(t, err)
	otherCheckpoint := NewCheckpoint(missionID, otherThread.ID)
	otherCheckpoint.ID = "other-checkpoint"
	err = checkpointStore.SaveCheckpoint(ctx, otherCheckpoint)
	require.NoError(t, err)

	_, err = tm.CreateBranchThread(ctx, parentThread.ID, otherCheckpoint.ID)
	assert.Error(t, err)
	assert.Contains(t, err.Error(), "does not belong to parent thread")
}

func TestThreadManager_GetThread(t *testing.T) {
	ctx := context.Background()
	threadStore := newMockThreadStore()
	checkpointStore := newMockCheckpointStore()
	tm := NewThreadManager(threadStore, checkpointStore)

	missionID := types.NewID()

	// Create thread
	thread, err := tm.CreateThread(ctx, missionID, WithThreadID("test"))
	require.NoError(t, err)

	// Get thread
	retrieved, err := tm.GetThread(ctx, thread.ID)
	require.NoError(t, err)
	assert.Equal(t, thread.ID, retrieved.ID)
	assert.Equal(t, thread.MissionID, retrieved.MissionID)

	// Test invalid thread ID
	_, err = tm.GetThread(ctx, "")
	assert.ErrorIs(t, err, ErrInvalidThreadID)

	// Test non-existent thread
	_, err = tm.GetThread(ctx, "nonexistent")
	assert.ErrorIs(t, err, ErrThreadNotFound)
}

func TestThreadManager_ListThreads(t *testing.T) {
	ctx := context.Background()
	threadStore := newMockThreadStore()
	checkpointStore := newMockCheckpointStore()
	tm := NewThreadManager(threadStore, checkpointStore)

	mission1 := types.NewID()
	mission2 := types.NewID()

	// Create threads for mission 1
	_, err := tm.CreateThread(ctx, mission1)
	require.NoError(t, err)
	_, err = tm.CreateThread(ctx, mission1)
	require.NoError(t, err)

	// Create thread for mission 2
	_, err = tm.CreateThread(ctx, mission2)
	require.NoError(t, err)

	// List threads for mission 1
	threads, err := tm.ListThreads(ctx, mission1)
	require.NoError(t, err)
	assert.Len(t, threads, 2)

	// List threads for mission 2
	threads, err = tm.ListThreads(ctx, mission2)
	require.NoError(t, err)
	assert.Len(t, threads, 1)

	// Test invalid mission ID
	_, err = tm.ListThreads(ctx, types.ID(""))
	assert.ErrorIs(t, err, ErrInvalidMissionID)
}

func TestThreadManager_UpdateThreadStatus(t *testing.T) {
	ctx := context.Background()
	threadStore := newMockThreadStore()
	checkpointStore := newMockCheckpointStore()
	tm := NewThreadManager(threadStore, checkpointStore)

	missionID := types.NewID()

	// Create thread
	thread, err := tm.CreateThread(ctx, missionID, WithThreadID("test"))
	require.NoError(t, err)
	assert.Equal(t, ThreadStatusActive, thread.Status)

	// Update to paused
	err = tm.UpdateThreadStatus(ctx, thread.ID, ThreadStatusPaused)
	require.NoError(t, err)

	updated, err := tm.GetThread(ctx, thread.ID)
	require.NoError(t, err)
	assert.Equal(t, ThreadStatusPaused, updated.Status)

	// Update to completed
	err = tm.UpdateThreadStatus(ctx, thread.ID, ThreadStatusCompleted)
	require.NoError(t, err)

	updated, err = tm.GetThread(ctx, thread.ID)
	require.NoError(t, err)
	assert.Equal(t, ThreadStatusCompleted, updated.Status)
	assert.NotNil(t, updated.CompletedAt)

	// Try to update terminal thread
	err = tm.UpdateThreadStatus(ctx, thread.ID, ThreadStatusActive)
	assert.Error(t, err)
	assert.Contains(t, err.Error(), "terminal")

	// Test invalid thread ID
	err = tm.UpdateThreadStatus(ctx, "", ThreadStatusPaused)
	assert.ErrorIs(t, err, ErrInvalidThreadID)

	// Test non-existent thread
	err = tm.UpdateThreadStatus(ctx, "nonexistent", ThreadStatusPaused)
	assert.Error(t, err)
}

func TestThreadManager_DeleteThread(t *testing.T) {
	ctx := context.Background()
	threadStore := newMockThreadStore()
	checkpointStore := newMockCheckpointStore()
	tm := NewThreadManager(threadStore, checkpointStore)

	missionID := types.NewID()

	// Create thread
	thread, err := tm.CreateThread(ctx, missionID, WithThreadID("test"))
	require.NoError(t, err)

	// Create checkpoint for thread
	checkpoint := NewCheckpoint(missionID, thread.ID)
	err = checkpointStore.SaveCheckpoint(ctx, checkpoint)
	require.NoError(t, err)

	// Delete thread
	err = tm.DeleteThread(ctx, thread.ID)
	require.NoError(t, err)

	// Verify thread is deleted
	_, err = tm.GetThread(ctx, thread.ID)
	assert.ErrorIs(t, err, ErrThreadNotFound)

	// Verify checkpoints are deleted
	_, err = checkpointStore.GetCheckpoint(ctx, checkpoint.ID)
	assert.ErrorIs(t, err, ErrCheckpointNotFound)

	// Test invalid thread ID
	err = tm.DeleteThread(ctx, "")
	assert.ErrorIs(t, err, ErrInvalidThreadID)

	// Test non-existent thread
	err = tm.DeleteThread(ctx, "nonexistent")
	assert.Error(t, err)
}

func TestThreadManager_GenerateSubgraphThreadID(t *testing.T) {
	threadStore := newMockThreadStore()
	checkpointStore := newMockCheckpointStore()
	tm := NewThreadManager(threadStore, checkpointStore)

	parentThread := "parent-thread-id"
	nodeID := "node-123"

	subgraphID := tm.GenerateSubgraphThreadID(parentThread, nodeID)

	assert.Contains(t, subgraphID, parentThread)
	assert.Contains(t, subgraphID, nodeID)
	assert.True(t, IsSubgraphThread(subgraphID))

	// Parse the ID
	parent, node, uuid, err := ParseThreadID(subgraphID)
	require.NoError(t, err)
	assert.Equal(t, parentThread, parent)
	assert.Equal(t, nodeID, node)
	assert.NotEmpty(t, uuid)
}

func TestParseThreadID(t *testing.T) {
	// Test hierarchical thread ID
	parent, node, uuid, err := ParseThreadID("parent:node:uuid123")
	require.NoError(t, err)
	assert.Equal(t, "parent", parent)
	assert.Equal(t, "node", node)
	assert.Equal(t, "uuid123", uuid)

	// Test simple thread ID
	parent, node, uuid, err = ParseThreadID("simple-thread-id")
	require.NoError(t, err)
	assert.Empty(t, parent)
	assert.Empty(t, node)
	assert.Equal(t, "simple-thread-id", uuid)

	// Test empty thread ID
	_, _, _, err = ParseThreadID("")
	assert.ErrorIs(t, err, ErrInvalidThreadID)

	// Test invalid format
	_, _, _, err = ParseThreadID("invalid:format")
	assert.Error(t, err)
}

func TestIsSubgraphThread(t *testing.T) {
	assert.True(t, IsSubgraphThread("parent:node:uuid"))
	assert.False(t, IsSubgraphThread("simple-thread"))
	assert.False(t, IsSubgraphThread("invalid:format"))
	assert.False(t, IsSubgraphThread(""))
}
