# AUTHORITATIVE-FGA-MODEL
#
# This file is the authoritative, hand-maintained OpenFGA authorization model.
# It is applied to the FGA server by the gibson-fga-init Kubernetes Job on every
# helm install/upgrade (the chart embeds files/fga-model.json, regenerated from
# this file via `make sync-fga-model` -> cmd/gen-fga-model-json).
#
# Gibson Authorization Model
#
# This file is the single source of truth for the OpenFGA authorization model.
# It is applied to the FGA server by the gibson-fga-init Kubernetes Job on every
# helm install/upgrade. Changes here must pass CI (fga-smoke-test.yml) before merge.
#
# When extending, add new types after system_tenant. Do NOT rename existing
# relations or types — doing so breaks existing tuples in the FGA store.
#
# Spec: tenant-role-taxonomy
#
# MODEL SCOPE
# -----------
# user            — a human or service principal identified by UUID
# tenant          — a Gibson customer organization (slug-addressed)
# agent_principal — a per-agent identity for scoped capability grants (Agent Auth Protocol)
# component       — an agent, tool, or plugin registered in the Gibson component registry
# system_tenant   — a singleton object (system_tenant:_system) that models
#                   cross-tenant platform-operator privilege
# team            — a subdivision of a tenant for grouping users and controlling data access
#
# TENANT THREE-TIER ROLE HIERARCHY (spec: tenant-role-taxonomy)
# -------------------------------------------------------------
# The tenant type exposes three user-facing roles in a strict computed-union
# hierarchy. Roles are additive upward: an owner implicitly satisfies admin
# and member checks; an admin implicitly satisfies member checks.
#
#   owner  (highest) — founding user or explicitly-assigned owner.
#                      Direct tuple grant only: [user].
#                      Written by the tenant-owner-backfill Job on migration;
#                      written by the signup action for new tenants.
#
#   admin  (middle)  — tenant administrator.
#                      Direct grant OR inherited from owner via computed union.
#                      Definition: [user] or owner
#
#   member (lowest)  — any authenticated tenant participant.
#                      Direct grant OR inherited from admin (which includes owner).
#                      Definition: [user] or admin
#
# This means:
#   Check(user:alice, admin,  tenant:acme) → true  when alice is owner of acme
#   Check(user:alice, member, tenant:acme) → true  when alice is owner or admin of acme
#   Check(user:bob,   owner,  tenant:acme) → false when bob is only admin of acme
#   Check(user:carol, owner,  tenant:acme) → false when carol is only member of acme
#
# RELATION SEMANTICS
# ------------------
# tenant.owner        → user is the founding/highest-privilege user of the tenant
#                       (direct grant only; computed union propagates downward)
# tenant.admin        → user is an administrator of the tenant
#                       (direct grant OR inherited from owner via computed union)
# tenant.member       → user is a member (direct grant OR inherited from admin,
#                       which by computed union includes owner)
# agent_principal.owner      → user that owns/created this agent principal
# agent_principal.belongs_to → tenant this agent principal is scoped to
# component.owner     → a tenant owns this component
# component.can_execute  → user/agent_principal can run this component (direct grant OR via tenant membership)
# component.can_configure → user/agent_principal can modify this component's config (direct grant OR via tenant membership)
# component.can_read  → user/agent_principal can read this component's output/data (direct grant OR via tenant/team membership)
# system_tenant.platform_operator → user has cross-tenant elevated privilege
# team.parent         → the tenant this team belongs to
# team.admin          → user is an admin of the team (or inherits tenant admin)
# team.member         → user is a member of the team (includes team admins)
# team.can_view_data_from → team A has crosstalk visibility into team B's data
#
# Tuple examples (tenant three-tier hierarchy):
#   user:alice   | owner            | tenant:acme       (founding user; satisfies admin + member checks)
#   user:bob     | admin            | tenant:acme       (satisfies member checks; does NOT satisfy owner)
#   user:carol   | member           | tenant:acme       (lowest role; does NOT satisfy admin or owner)
#
# Tuple examples (other types):
#   tenant:acme  | owner            | component:nmap
#   user:alice   | can_execute      | component:nmap    (computed: admin→member→can_execute)
#   user:root    | platform_operator | system_tenant:_system
#   team:ops     | parent           | tenant:acme
#   user:alice   | admin            | team:ops
#   user:bob     | member           | team:ops
#   team:alpha   | can_view_data_from | team:beta
#   user:alice        | owner      | agent_principal:agent-abc-123
#   tenant:acme       | belongs_to | agent_principal:agent-abc-123
#   agent_principal:agent-abc-123 | can_execute | component:nmap   (direct per-agent grant)
#   agent_principal:agent-abc-123 | cannot_invoke      | component:gitlab-plugin  (per-agent DENY override)
#   component:nmap-agent          | can_be_invoked_by  | component:scan-controller (explicit component→component invocation grant)

# Cross-component relations (added for capability-manifest-rpc):
#   agent_principal.cannot_invoke    → explicit DENY on (agent, target_component); overrides positive can_execute.
#   component.can_be_invoked_by      → explicit ALLOW enabling the manifest builder to surface
#                                      component→component "may invoke" rules without enumerating
#                                      every (source, target) pair via Check.
# The effective cross-component rule resolution lives in FGABridge.ResolveCrossComponentRules:
#   DENY if cannot_invoke is true; else ALLOW if can_execute or can_be_invoked_by is true;
#   else absent (the default can_execute check remains the gate).

model
  schema 1.1

type user

type tenant
  relations
    define owner: [user]
    define admin: [user] or owner
    define member: [user] or admin
    # Informational feature-availability flags written by the tenant-operator
    # from the resolved plan. These are self-referential (tenant:X#has_Y@tenant:X)
    # and gate UI affordances only; they do not participate in catalog
    # access checks. Spec: agent-authoring-and-tenant-entitlements R4, R7.
    define has_sso: [tenant]
    define has_audit_logs: [tenant]
    define has_compliance_exports: [tenant]
    define has_dedicated_slack: [tenant]
    define has_dedicated_tenant: [tenant]
    define has_private_registry: [tenant]

type agent_principal
  relations
    define owner: [user]
    define belongs_to: [tenant]
    define cannot_invoke: [component]

# tool_principal — a per-tool machine identity provisioned via
# TenantAdminService.CreateAgentIdentity with kind=TOOL.
# Mirrors agent_principal shape. Spec: agent-service-credentials.
type tool_principal
  relations
    define owner: [user]
    define belongs_to: [tenant]
    define cannot_invoke: [component]

# plugin_principal — a per-plugin machine identity provisioned via
# TenantAdminService.CreateAgentIdentity with kind=PLUGIN.
# Mirrors agent_principal shape. Spec: agent-service-credentials.
type plugin_principal
  relations
    define owner: [user]
    define belongs_to: [tenant]
    define cannot_invoke: [component]

type component
  relations
    define owner: [tenant]
    # Ownership / publication scope (agent-authoring-and-tenant-entitlements R3):
    # platform_enabled — item is in the system-tenant's public catalog
    # tenant_published — item is in its owning tenant's private registry (org+ plans only)
    # tenant_enabled   — a given tenant has this item available (seeded per-tenant by operator)
    define platform_enabled: [system_tenant]
    define tenant_published: [tenant]
    define tenant_enabled: [tenant]
    # Tenant-level per-action denies — tenant-admin wholesale kill switches.
    define tenant_read_disabled: [tenant]
    define tenant_write_disabled: [tenant]
    define tenant_execute_disabled: [tenant]
    # Team-level per-action denies via team membership. Subject is team#member,
    # so a user in any team with a given deny set loses that action.
    define team_read_disabled: [team#member]
    define team_write_disabled: [team#member]
    define team_execute_disabled: [team#member]
    # User-level per-action denies — personal opt-out on My access UI.
    define user_read_disabled: [user]
    define user_write_disabled: [user]
    define user_execute_disabled: [user]
    # Component-scope per-action grants for agent_principal narrowing
    # (owner approves at agent install time). Default absent = denied.
    define component_read_enabled: [agent_principal]
    define component_write_enabled: [agent_principal]
    define component_execute_enabled: [agent_principal]
    # Effective per-action evaluators — existing relation names preserved so
    # call sites keep compiling. Each layers the ownership/scope gate onto
    # the direct grant set and subtracts every matching deny relation.
    # Deny-wins composition; denies are union-subtracted (union of any deny
    # at any layer => overall deny at that action class).
    # any_execute_deny / any_write_deny / any_read_deny collect all per-action
    # denies across scopes so the user-facing relations need a single `but not`.
    define any_execute_deny: tenant_execute_disabled or team_execute_disabled or user_execute_disabled
    define any_write_deny: tenant_write_disabled or team_write_disabled or user_write_disabled
    define any_read_deny: tenant_read_disabled or team_read_disabled or user_read_disabled
    # owner-side direct/role grant (pre-gate).
    define direct_execute: [user, agent_principal, tenant#member, team#member] or admin from owner
    define direct_configure: [user, agent_principal, tenant#member, team#member] or admin from owner
    define direct_read: [user, agent_principal, tenant#member, team#member, team#can_view_data_from] or admin from owner
    # ownership gate: visible iff published to the caller's scope AND tenant_enabled.
    define in_tenant_catalog: (platform_enabled or tenant_published) and tenant_enabled
    # Effective per-action evaluators. Preserving the existing relation names
    # means legacy Check(subject, can_read, component) call sites pick up the
    # deny-wins composition automatically.
    define can_execute: (direct_execute and in_tenant_catalog) but not any_execute_deny
    define can_configure: (direct_configure and in_tenant_catalog) but not any_write_deny
    define can_read: (direct_read and in_tenant_catalog) but not any_read_deny
    # Component-scope effective relations — evaluated when the caller is an
    # agent_principal. Each requires both the owner-side action (via can_*)
    # AND the per-component grant tuple. component_scope JWT claim narrowing
    # (R2) is enforced at the interceptor against these relations.
    define can_read_as_component: can_read and component_read_enabled
    define can_write_as_component: can_configure and component_write_enabled
    define can_execute_as_component: can_execute and component_execute_enabled
    define can_be_invoked_by: [agent_principal, component]

type system_tenant
  relations
    define platform_operator: [user]

type team
  relations
    define parent: [tenant]
    define admin: [user] or admin from parent
    define member: [user, team#admin]
    define can_view_data_from: [team]

# mission_definition — per-tenant container for structured mission definitions
# registered via gibson.daemon.v1.DaemonService/CreateMissionDefinition. The
# per-tenant singleton object is addressed as `mission_definition:_tenant_<slug>`
# and checked by the CreateMissionDefinition RPC authz rule. `writer` is granted
# only to users who are admin of the parent tenant — no direct user grants
# intended; contribute via tenant admin membership only.
#
# can_view / can_execute / can_list added under spec
# phase-1-daemon-critical-exfil-fixes (Task 4) so per-resource authz checks
# have a typed relation to bind against. Per-request tuples are NEVER written;
# the only writers are resource creation (Phase 2 provisioning hook) and the
# BackfillResourceParents routine in backfill.go (Phase 1 flag-gated off).
type mission_definition
  relations
    define parent: [tenant]
    define writer: admin from parent
    define can_view: member from parent
    define can_execute: member from parent
    define can_list: member from parent

# mission — a parameterised mission instance scoped to a tenant. Created via
# gibson.daemon.v1.DaemonService/CreateMission. `parent` links the mission to
# its owning tenant; per-request authz checks bind against can_view /
# can_execute / can_list. Per-request tuples are never written; tuples are
# produced only by Create (Phase 2) and BackfillResourceParents (see
# backfill.go). Added under spec phase-1-daemon-critical-exfil-fixes Task 4.
type mission
  relations
    define parent: [tenant]
    define can_view: member from parent
    define can_execute: member from parent
    define can_list: member from parent

# run — a mission execution instance (invocation of a mission against a
# target) scoped to a tenant. Follows the same parent/relation shape as
# mission. Added under spec phase-1-daemon-critical-exfil-fixes Task 4.
type run
  relations
    define parent: [tenant]
    define can_view: member from parent
    define can_execute: member from parent
    define can_list: member from parent

# target — a scan target (system / endpoint / asset) scoped to a tenant.
# Follows the same parent/relation shape as mission. Added under spec
# phase-1-daemon-critical-exfil-fixes Task 4.
type target
  relations
    define parent: [tenant]
    define can_view: member from parent
    define can_execute: member from parent
    define can_list: member from parent

# finding — a security finding emitted by a mission run, scoped to a tenant.
# Read-only: findings are produced by tools/agents and consumed by the
# dashboard; there is no "execute a finding" operation. Added under spec
# phase-1-daemon-critical-exfil-fixes Task 4.
type finding
  relations
    define parent: [tenant]
    define can_view: member from parent
    define can_list: member from parent

# tenant_component — per-tenant view of a registered component (agent /
# tool / plugin) for resource-level authz. The existing `component` type
# (above) carries the catalog-gating and deny-wins access model; this
# tenant-parented companion type expresses "this component belongs to
# tenant X" so can_view / can_execute / can_register / can_list can be
# bound as simple member-from-parent relations. Added under spec
# phase-1-daemon-critical-exfil-fixes Task 4. The original `component`
# type is NOT modified — per task restrictions, existing tenant membership
# semantics are preserved.
type tenant_component
  relations
    define parent: [tenant]
    define can_view: member from parent
    define can_execute: member from parent
    define can_register: admin from parent
    define can_list: member from parent

# ----------------------------------------------------------------------
# LLM provider / model access gating — spec `llm-user-attribution-governance`
# ----------------------------------------------------------------------
#
# provider and model types enable per-user / per-team / per-tenant gating
# of slot resolution. Absent tuples = permit-all (backwards compatible
# with today's behavior); gating kicks in once any tuple exists.
#
# Tuple examples:
#   tenant:acme               | owner   | provider:anthropic
#   user:alice                | can_use | provider:anthropic
#   team:engineering#member   | can_use | provider:openai
#   tenant:acme#member        | can_use | provider:anthropic   (grant to all members)
#   provider:anthropic        | provider | model:claude-opus-4
#   role:senior               | can_use | model:claude-opus-4     (not yet wired)
#
# can_use on model is a computed-union: direct tuple OR inherited from
# the provider, so granting provider:anthropic:can_use to a user grants
# them every model on that provider automatically.

type provider
  relations
    define owner: [tenant]
    define can_use: [user, team#member, tenant#member]

type model
  relations
    define provider: [provider]
    define owner: [tenant]
    define can_use: [user, team#member, tenant#member] or can_use from provider

# ----------------------------------------------------------------------
# Secret resource type — spec `secrets-broker` Phase 8
# ----------------------------------------------------------------------
#
# `secret` represents a named opaque value governed by the SecretsBroker.
# The structural enforcement property: only plugin_principal callers may
# resolve (read plaintext) a secret. agent_principal and tool_principal
# have NO relation to secret — their absence from can_resolve is the
# structural gate, not just a policy default.
#
# Relation semantics:
#   belongs_to   — ties the secret to its owning tenant for scoped queries
#   can_resolve  — grants plaintext read-back; plugin_principal ONLY
#   can_write    — dashboard / admin CRUD (user direct or via tenant#admin)
#   can_delete   — dashboard / admin delete (user direct or via tenant#admin)
#
# Tuple shape written by tenant-operator at plugin_principal provisioning:
#   (plugin_principal:<install_id>, can_resolve, secret:tenant-<tenant_id>:*)
#
# Tuple shape written by tenant-operator at tenant provisioning for the
# daemon's own service identity (LLM provider config resolution path):
#   (user:<daemon_service_id>, can_resolve, secret:tenant-<tenant_id>:*)
#
# agent_principal and tool_principal get NO tuples to any secret:* object.

type secret
  relations
    define belongs_to: [tenant]
    define can_resolve: [plugin_principal]
    define can_write: [user, tenant#admin]
    define can_delete: [user, tenant#admin]

# ----------------------------------------------------------------------
# Plugin resource type — spec `plugin-runtime` Phase 10 (Task 25)
# ----------------------------------------------------------------------
#
# `plugin` represents a registered plugin install reachable by tools via
# the `gibson.plugin.v1.PluginInvokeService.PluginInvoke` RPC. The RPC's
# authz annotation resolves the FGA object via `tenant_and_field('PluginName')`
# producing object IDs of the form `plugin:<tenant>:<plugin_name>` (see
# core/ext-authz/internal/fga/check.go:resolveObject). The relation checked
# at request time is `tool_principal#can_invoke@plugin:<tenant>:<plugin_name>`.
#
# Relation semantics:
#   belongs_to  — ties the plugin to its owning tenant for scoped queries
#   can_invoke  — grants tool_principal (or any tenant member) the ability
#                 to invoke this plugin's methods. agent_principal is
#                 intentionally excluded: agents dispatch tools; tools
#                 invoke plugins (per Requirement 5.2).
#
# Tuple shape written by tenant-operator at plugin registration (v1, tenant-wide):
#   (tenant:<tenant_id>#member, can_invoke, plugin:<tenant_id>:<plugin_name>)
#
# This grants every tenant member (including every tool_principal that
# inherits tenant membership) can_invoke on the registered plugin without
# enumerating per-(tool, plugin) pairs. Per-tool granular grants are
# out of scope for v1; the relation accepts `tool_principal` directly so
# fine-grained tuples can be added later without a model change.
#
# agent_principal is NOT in the can_invoke type list; absent direct grants
# combined with no computed-union path mean agents are structurally barred
# from invoking plugins.

type plugin
  relations
    define belongs_to: [tenant]
    define can_invoke: [tool_principal, tenant#member]
